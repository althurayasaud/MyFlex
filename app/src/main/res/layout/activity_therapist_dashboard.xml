<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Hero Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="64dp"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <!-- Therapist Avatar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="#4DFFFFFF"
                app:cardBackgroundColor="@color/primary_dark">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_person"
                    android:padding="16dp"
                    app:tint="@color/white"
                    tools:ignore="ContentDescription" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvTherapistName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dr. Therapist"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Physical Therapist"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textColor="@color/white"
                android:textAllCaps="false"
                app:rippleColor="#33FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content Card Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_top_rounded_card"
        android:layout_marginTop="140dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY PATIENTS"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPatients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="32dp"
                tools:listitem="@android:layout/simple_list_item_2" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THERAPIST TOOLS"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreatePlan"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="+ Create Exercise Plan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_feature_time"
                app:iconPadding="12dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/primary"
                android:elevation="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewReports"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="View AI Analytics"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_chart"
                app:iconPadding="12dp"
                android:backgroundTint="@color/accent_green"
                android:elevation="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use AI Analytics to review patient form accuracy and fatigue levels automatically."
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
