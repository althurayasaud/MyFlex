<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_message_received.xml -->
<!-- Received message: white bubble with avatar, aligned to the left -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingTop="3dp"
    android:paddingBottom="3dp"
    android:paddingStart="4dp"
    android:paddingEnd="56dp">

    <!-- Sender avatar (shows initials) -->
    <androidx.cardview.widget.CardView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#1D4ED8"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/chat_initials_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="DT" />
    </androidx.cardview.widget.CardView>

    <!-- Bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_bubble_received"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="7dp">

        <!-- Message text -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="240dp"
            android:text="@string/chat_message_placeholder"
            android:textColor="#1E293B"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"
            tools:text="Hello" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="3dp"
            android:text="@string/chat_time_placeholder"
            android:textColor="#475569"
            android:textSize="12sp"
            tools:text="10:31 AM" />

    </LinearLayout>
</LinearLayout>