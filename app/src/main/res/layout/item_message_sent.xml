<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_message_sent.xml -->
<!-- Sent message: blue bubble aligned to the right -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="horizontal"
    android:paddingTop="3dp"
    android:paddingBottom="3dp"
    android:paddingStart="56dp"
    android:paddingEnd="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_bubble_sent"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="7dp">

        <!-- Message text -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="240dp"
            android:text="@string/chat_message_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"
            tools:text="Hello" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="3dp"
            android:text="@string/chat_time_placeholder"
            android:textColor="#E0F2FE"
            android:textSize="11sp"
            tools:text="10:30 AM" />

    </LinearLayout>
</LinearLayout>